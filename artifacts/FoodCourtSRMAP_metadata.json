				},
				"balanceOf(address)": {
					"details": "Returns the account balance of another account with address _owner."
				},
				"constructor": {
					"details": "Constructor sets the total supply and assigns it to the deployer. Total Supply: 100,000 * 10^18 (to account for decimals)"
				},
				"transfer(address,uint256)": {
					"details": "Transfers _value amount of tokens to address _to."
				},
				"transferFrom(address,address,uint256)": {
					"details": "Transfers _value amount of tokens from address _from to address _to. Used by the canteen (spender) to deduct tokens from a student (owner)."
